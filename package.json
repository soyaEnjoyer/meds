{
  "name": "meds",
  "displayName": "Meds",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "cp /mnt/docker/meds/data.db* .local/",
    "db:reset": "rm .local/data.db; drizzle-kit migrate",
    "dead": "pnpx fallow",
    "dev": "vite dev",
    "docker": "pnpm docker:build && pnpm docker:run",
    "docker:build": "docker build --tag meds:latest --progress plain .",
    "docker:run": "docker run --name meds -h meds -it --rm -p 3000:3000 -v ./.local/:/config/ meds:latest",
    "format": "oxfmt",
    "lint": "oxlint --fix",
    "lint:fix": "oxlint --fix --fix-suggestions",
    "local": "pnpm build && pnpm start",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@libsql/client": "^0.17.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-start": "^1.167.42",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/eslint-plugin-query": "^5.99.2",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "fallow": "^2.44.0",
    "nitro": "3.0.260415-beta",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tailwindcss": "^4.2.3",
    "vite": "^8.0.9"
  }
}
