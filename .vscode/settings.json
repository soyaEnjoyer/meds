{
  "[css]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "biome.enabled": false,
  "editor.codeActionsOnSave": {
    "source.format.oxc": "explicit",
    "source.fixAll.oxc": "explicit"
  },
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.formatOnType": false,
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  },
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "js/ts.experimental.useTsgo": true,
  "oxc.enable": true,
  "peacock.color": "#ae69e6",
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "todo-tree.tree.disableCompactFolders": false,
  "todo-tree.tree.showBadges": true,
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#c695ed",
    "activityBar.background": "#c695ed",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#faf0e4",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#c695ed",
    "statusBar.background": "#ae69e6",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#963ddf",
    "statusBarItem.remoteBackground": "#ae69e6",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#ae69e6",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#ae69e699",
    "titleBar.inactiveForeground": "#15202b99"
  }
}
