{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/src/index.js",
    "dev": "nodemon src/index.ts",
    "debug": "DEBUG=express:* nodemon src/index.ts",
    "schema_gen": "npx drizzle-kit generate",
    "schema_push": "npx drizzle-kit push",
    "schema_migrate": "npx drizzle-kit migrate",
    "db_pull": "python3 load_database.py",
    "db_pull_live": "python3 load_database.py -live",
    "db_rebuild": "echo 'rm -rf drizzle/* data.db; npx drizzle-kit generate; npx drizzle-kit migrate; python3 load_database.py'",
    "db_copy_local": "scp manage@media:/docker/home/meds/data.db* ./"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "better-sqlite3": "^11.2.1",
    "drizzle-kit": "^0.24.2",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.2",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
